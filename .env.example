# Postgres (consumido por docker-compose y por el backend)
POSTGRES_USER=northwind
POSTGRES_PASSWORD=northwind
POSTGRES_DB=northwind
# Usamos 5433 para no chocar con Postgres locales (instalados via brew, etc)
POSTGRES_PORT=5433

# DATABASE_URL es lo que usan el backend Go y el CLI de golang-migrate
DATABASE_URL=postgres://northwind:northwind@localhost:5433/northwind?sslmode=disable

# DB separada para tests de integracion
TEST_DATABASE_URL=postgres://northwind:northwind@localhost:5433/northwind_test?sslmode=disable

# Backend HTTP server
SERVER_PORT=8080

# CORS (origen permitido en desarrollo)
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Puerto donde se expone el frontend (modo docker compose up)
FRONTEND_PORT=5173

# Variable consumida solo por el frontend en build local (vite). En modo
# docker se hardcodea http://localhost:8080 via el client.ts default.
VITE_API_BASE_URL=http://localhost:8080
